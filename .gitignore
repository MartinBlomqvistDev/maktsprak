# ----------------------------------------------------
# 1. VIRTUELLA MILJÖER & PYTHON ARTEFAKTER
# ----------------------------------------------------
.venv/
venv/
env/

# Python cache och kompilerade filer
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# ----------------------------------------------------
# 2. DATA SCIENCE & MODELL-ARTEFAKTER (MÅSTE IGNORERAS)
# ----------------------------------------------------

data/raw/*
data/raw/**
*.pdf

# Databaser och mappar (KRITISK KORRIGERING)
data/db/               # IGNORERAR HELA MAPPARNA data/db/
data/db/maktsprakai.db
*.db                   # IGNORERAR ALLA filer med .db
*.sqlite
data/parquet/
*.parquet


# Lokalt sparade modeller och temporära filer från träning
*.pt
*.bin
*.pkl
*.safetensors
data/models/*
!data/models/README.md
/.env

# ----------------------------------------------------
# 3. STREAMLIT & CLOUD ARTEFAKTER
# ----------------------------------------------------

.streamlit/credentials.toml
.streamlit/secrets.toml
.streamlit/cache/

# Temporära filer från molntjänster
tmp/
st_cache/

# ----------------------------------------------------
# 4. OS- OCH IDE-FILER
# ----------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
.claude/

# Loggfiler
*.log

# Utvärderingsartefakter (benchmark-körningar, confusion-matriser)
results/
results_new_model/

# ----------------------------------------------------
# 5. WEB (Next.js/Vercel site under web/)
# ----------------------------------------------------
web/node_modules/
web/.next/
web/.env
web/.env*.local
# web/src/data/*.json (precomputed site data) stays tracked — Vercel's build
# has no Python runtime, so those JSON files ARE the deploy artifact.