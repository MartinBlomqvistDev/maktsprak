# ============================================================
# MaktspråkAI — environment variables
# Copy this file to .env and fill in your own values.
# Never commit .env to version control.
# ============================================================

# ---------------------------
# Supabase (required)
# ---------------------------
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_KEY=your-anon-public-key
# Service-role key bypasses Row Level Security for write operations.
SUPABASE_SERVICE_KEY=your-service-role-key

# ---------------------------
# Twitter / X API (optional)
# Omit if you don't want tweet collection.
# ---------------------------
X_BEARER_TOKEN=your-twitter-bearer-token

# ---------------------------
# PostgreSQL direct connection (optional)
# Only needed if you connect to Supabase via psycopg2 directly.
# ---------------------------
DB_HOST=db.yourproject.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-db-password

# ---------------------------
# External data (optional)
# Direct-download URL for the historical Parquet snapshot.
# ---------------------------
PARQUET_URL=https://drive.google.com/uc?export=download&id=your-file-id

# ---------------------------
# Overrides (optional)
# ---------------------------
# LOG_LEVEL=DEBUG
# MODEL_NAME_OR_PATH=MartinBlomqvist/maktsprak_classifier_clean
